# Local overrides for development
# Copy this file to local.properties and fill in your values.

# Folder that contains translation JSON files.
myapp.local.dataDir=data

# Optional path to a Google service-account JSON key used for
# Application Default Credentials. If blank, ADC fallback applies
# (GOOGLE_APPLICATION_CREDENTIALS env var, gcloud ADC file, or
# attached service account on Google Cloud).
myapp.local.googleCredentialsPath=

# Default source language for Google translation requests.
# Example values: en, bg
myapp.local.googleSourceLanguage=

# Default target language for Google translation requests.
# Example values: bg, en
myapp.local.googleTargetLanguage=

# Google project id used for v3 Translation API requests.
myapp.local.googleProjectId=

# Google Cloud Translation location. Keep "global" unless you use
# region-specific resources like custom glossaries.
myapp.local.googleLocation=global

# Google Translation model to use.
myapp.local.googleModel=general/translation-llm

# Enable glossary for Google translation requests.
myapp.local.googleGlossaryEnabled=false

# Optional glossary id or full glossary path for Translation LLM.
# Example short id: app-terms
# Example full path: projects/my-project/locations/us-central1/glossaries/app-terms
myapp.local.googleGlossaryId=

# Max number of strings sent per Google Translate API request.
myapp.local.googleBatchSize=50

# Language code used by Google when returning the display names
# in /languages API (for example: en, fr, de, ar).
myapp.local.supportedLanguagesDisplayLocale=en

# Default target language pre-selected in the UI.
myapp.local.uiPreferredTargetLanguage=fr

# Reference language used to populate the "Reference" column.
# Example values: en, fr
myapp.local.referenceLanguageFile=en

# Optional path to a newline-delimited list of additional risky terms.
# Relative paths are resolved from the configured data directory.
myapp.local.riskyTermsFile=risky-terms.txt

# Protect placeholders like {{name}} / {id} / %s before translation.
myapp.local.placeholderProtectionEnabled=true

# Write validation report files and row-level quality checks.
myapp.local.validationEnabled=true

# ------------------------------------------------------------------------
# Recently added sync variables (latest branches), grouped at the end
# for easier local-vs-example comparison.
# ------------------------------------------------------------------------

# Optional local glossary CSV path. Relative paths are resolved from dataDir.
myapp.local.googleGlossaryFile=glossary.csv

# GCS bucket used to upload glossary CSV files for automated sync.
myapp.local.googleGlossaryBucket=

# Optional object prefix/folder within the glossary bucket.
myapp.local.googleGlossaryObjectPrefix=translation-glossaries

# Optional template for generated glossary ids.
# Supported placeholders: {source}, {target}
myapp.local.googleGlossaryResourceTemplate=app-glossary-{source}-{target}

# Optional local adaptive dataset TSV path. Relative paths are resolved from dataDir.
myapp.local.googleAdaptiveDatasetFile=adaptive-dataset.tsv

# GCS bucket used to upload adaptive dataset TSV files for automated sync.
myapp.local.googleAdaptiveDatasetBucket=

# Optional object prefix/folder within the adaptive dataset bucket.
myapp.local.googleAdaptiveDatasetObjectPrefix=adaptive-datasets

# Optional template for generated adaptive dataset ids.
# Supported placeholders: {source}, {target}
myapp.local.googleAdaptiveDatasetResourceTemplate=app-adaptive-{source}-{target}

# Enable adaptive dataset usage during translation.
# Set to false to translate using glossary/LLM path only.
myapp.local.googleAdaptiveDatasetEnabled=true

# CRM specific directories
myapp.local.crmSourceFilesDirectory=data/crm/source
myapp.local.crmGlossaryDirectory=data/crm/glossary
myapp.local.crmAdaptiveDatasetDirectory=data/crm/adaptive
myapp.local.crmTranslatedJsonDirectory=data/crm/translated

# Self Service (CSS) specific directories
myapp.local.selfServiceSourceFilesDirectory=data/self-service/source
myapp.local.selfServiceGlossaryDirectory=data/self-service/glossary
myapp.local.selfServiceAdaptiveDatasetDirectory=data/self-service/adaptive
myapp.local.selfServiceTranslatedJsonDirectory=data/self-service/translated
